# Primary model credential — used for all model roles (main, vision, auxiliary, fallback)
OPENROUTER_API_KEY=sk-or-...
# Optional alternative model provider (not used by default; switch hermes/config.yaml providers to use it)
# OPENCODE_GO_API_KEY=your_opencode_go_api_key
# comma-separated allowed hosts for external image download
IMAGE_DOWNLOAD_ALLOWED_HOSTS=
HERMES_IMAGE=ghcr.io/cgaravitoq/hermes-slim:latest

# Agent / store branding (mirrored in hermes/config.yaml)
AGENT_NAME=Shopkeeper
OWNER_NAME=your_owner_name
CLIENT_NAME=your_client_name
STORE_NAME=your_store_name
LOCALE=en

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Numeric Telegram IDs allowed to talk to the agent, comma-separated
TELEGRAM_ALLOWED_USERS=admin_id,operator_id,client_id
# Telegram chat IDs for cron routing
# Admin receives system crons (monitor, cleanup)
TELEGRAM_ADMIN_CHAT=your_admin_chat_id
# Business recipients receive business crons (engagement, seo, report)
TELEGRAM_CLIENT_CHATS=your_client_chat_id
# Backward-compatible single-recipient fallback
TELEGRAM_CLIENT_CHAT=your_client_chat_id
# Home channel (defaults to admin)
TELEGRAM_HOME_CHANNEL=your_home_channel_id
TELEGRAM_HOME_CHANNEL_NAME="Store Updates"

SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_API_VERSION=2026-01
# Shopify resolved ids (run the bootstrap helper to discover these)
BLOG_ID=your_blog_id
ONLINE_STORE_PUBLICATION_ID=your_online_store_publication_id
THEME_ID=your_theme_id
